{
  "name": "frontmatter-md",
  "version": "1.0.0",
  "description": "Lightweight YAML frontmatter parser for Markdown files.",
  "keywords": [
    "frontmatter",
    "front-matter",
    "markdown",
    "markdown-parser",
    "md",
    "parser",
    "frontmatter-parser",
    "yaml",
    "metadata"
  ],
  "homepage": "https://sefinek.net",
  "bugs": {
    "url": "https://github.com/sefinek/frontmatter-md/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sefinek/frontmatter-md.git"
  },
  "funding": {
    "type": "individual",
    "url": "https://sefinek.net/donate"
  },
  "license": "MIT",
  "author": "Sefinek <contact@sefinek.net> (https://sefinek.net)",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "require": "./src/index.js"
    }
  },
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "directories": {
    "example": "examples",
    "test": "test"
  },
  "files": [
    "dist",
    "src",
    "examples",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "lint": "eslint .",
    "m": "ncu -u && npm install && npm update",
    "test": "jest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true
  }
}
